// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id           String   @id @default(uuid())
  title        String
  category     Category
  image        String
  description  String
  fullContent  String   @db.Text
  techStack    String[]
  completedIn  String   // e.g. "2026"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Category {
  WEB
  APP
  MACHINE_LEARNING
  VERILOG_FSM
  ARDUINO_IOT
  ALGORITHM_FLOWCHART
  OTHERS
}
